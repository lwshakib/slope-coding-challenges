// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model CommunitySolution {
  id          String    @id @default(cuid())
  problemSlug String
  title       String
  content     String
  language    String
  code        String
  likes       Int       @default(0)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([problemSlug])
  @@map("community_solution")
}

model Comment {
  id                  String             @id @default(cuid())
  communitySolutionId String
  communitySolution   CommunitySolution  @relation(fields: [communitySolutionId], references: [id], onDelete: Cascade)
  content             String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([communitySolutionId])
  @@map("comment")
}




model Submission {
  id          String   @id @default(cuid())
  problemSlug String
  code        String
  language    String
  status      String   @default("PENDING") // PENDING, ACCEPTED, FAILED
  output      String?
  notes       String?
  runtime     Float?   // Total/Max runtime in ms
  memory      Float?   // Max memory used in KB
  createdAt   DateTime @default(now())
  testResults TestCaseResult[]

  @@index([problemSlug])
  @@map("submission")
}

model TestCaseResult {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  caseIdx      Int
  status       String     // PASSED, FAILED, RUNTIME_ERROR, etc.
  input        String
  expected     String
  actual       String?
  error        String?
  runtime      Float?     // ms
  memory       Float?     // KB
  createdAt    DateTime   @default(now())

  @@index([submissionId])
  @@map("test_case_result")
}

model TestRun {
  id          String   @id @default(cuid())
  problemSlug String
  code        String
  language    String
  status      String   @default("PENDING") // PENDING, ACCEPTED, FAILED
  output      String?
  runtime     Float?   // Total/Max runtime in ms
  memory      Float?   // Max memory used in KB
  createdAt   DateTime @default(now())
  testResults TestRunResult[]

  @@index([problemSlug])
  @@map("test_run")
}

model TestRunResult {
  id           String   @id @default(cuid())
  testRunId    String
  testRun      TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  caseIdx      Int
  status       String   // PASSED, FAILED, RUNTIME_ERROR, etc.
  input        String
  expected     String
  actual       String?
  error        String?
  runtime      Float?   // ms
  memory       Float?   // KB
  createdAt    DateTime @default(now())

  @@index([testRunId])
  @@map("test_run_result")
}


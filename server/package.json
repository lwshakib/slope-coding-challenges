{
  "name": "server",
  "module": "src/index.ts",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run dist/index.js",
    "ecs:setup": "bun run src/scripts/ecs-setup.ts",
    "ecs:teardown": "bun run src/scripts/ecs-teardown.ts",
    "postgres:setup": "bun run src/scripts/postgres-setup.ts",
    "postgres:teardown": "bun run src/scripts/postgres-teardown.ts",
    "infra:setup": "bun run postgres:setup && bun run ecs:setup",
    "infra:teardown": "bun run ecs:teardown && bun run postgres:teardown"
  },
  "private": true,
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1023.0",
    "@aws-sdk/client-ec2": "^3.1023.0",
    "@aws-sdk/client-ecr": "^3.1023.0",
    "@aws-sdk/client-ecs": "^3.1023.0",
    "@aws-sdk/client-iam": "^3.1023.0",
    "amqplib": "^0.10.9",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "winston": "^3.19.0",
    "zod": "^4.3.4"
  }
}
